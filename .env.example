# Supabase — get from: https://supabase.com/dashboard/project/<project-id>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://<project-id>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# Pipeline API keys
YOUTUBE_API_KEY=<youtube-data-api-v3-key>
VIRAL_APP_API_KEY=<viral-app-mcp-key>
APIFY_TOKEN=<apify-api-token>
META_APP_ID=<meta-app-id>
META_APP_SECRET=<meta-app-secret>
META_ACCESS_TOKEN=<meta-graph-api-access-token>

# Google Gemini — Gemini API for content brief and copy generation
GOOGLE_API_KEY=<google-api-key>

# OpenAI — DALL-E API for image generation
OPENAI_API_KEY=<openai-api-key>

# Pipeline Worker — URL where the Python pipeline HTTP server runs
# Required for cron/on-demand triggers to actually execute pipelines
PIPELINE_WORKER_URL=http://localhost:8000
PIPELINE_WORKER_SECRET=<shared-secret-between-cron-and-worker>

# Supabase URL for Python pipelines (not prefixed with NEXT_PUBLIC_)
SUPABASE_URL=https://<project-id>.supabase.co

# Vercel Cron (optional — protects /api/cron/* endpoints)
CRON_SECRET=<random-secret>
